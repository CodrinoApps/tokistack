{
  "name": "tokistack",
  "version": "0.0.0",
  "repository": "git@github.com:CodrinoApps/tokistack.git",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "turbo:build": "turbo run build",
    "turbo:build:api": "turbo run build --filter=@tokistack/api",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "stylelint": "dprint check",
    "prepare": "husky"
  },
  "lint-staged": {
    "packages/i18n/locales/*.json": [
      "pnpm --filter @tokistack/i18n validate"
    ],
    "*": [
      "pnpm dprint fmt --allow-no-files",
      "pnpm lint"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.1",
    "@commitlint/config-conventional": "20.4.1",
    "@eslint/js": "9.39.2",
    "angular-eslint": "21.2.0",
    "dprint": "0.51.1",
    "eslint": "9.39.2",
    "eslint-plugin-jest": "29.12.2",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "turbo": "2.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
