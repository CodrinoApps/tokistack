{
  "name": "@tokistack/email",
  "version": "1.0.0",
  "description": "Email package for Tokistack",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "preview": "tsc && node --experimental-strip-types --no-warnings scripts/preview.ts",
    "test": "vitest",
    "test:ci": "vitest run"
  },
  "exports": {
    ".": {
      "types": "./src/client.ts",
      "default": "./dist/client.js"
    },
    "./types": {
      "types": "./src/types.ts"
    },
    "./commands/send-waitlist-confirmation": {
      "types": "./src/commands/send-waitlist-confirmation.command.ts",
      "default": "./dist/commands/send-waitlist-confirmation.command.js"
    }
  },
  "dependencies": {
    "@tokistack/i18n": "workspace:*",
    "@tokistack/logger": "workspace:*",
    "mjml": "4.18.0",
    "resend": "6.10.0"
  },
  "devDependencies": {
    "@tokistack/typescript-config": "workspace:*",
    "@types/mjml": "4.7.4",
    "@types/node": "25.2.2",
    "typescript": "5.9.3",
    "vitest": "4.1.2"
  }
}
