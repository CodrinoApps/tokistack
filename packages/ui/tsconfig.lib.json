{
  "extends": "@tokistack/typescript-config/base.tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "preserve",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "dom"]
  },
  "angularCompilerOptions": {
    "strictTemplates": true,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "**/*.spec.ts",
    "node_modules",
    "dist",
    "out-tsc"
  ]
}
